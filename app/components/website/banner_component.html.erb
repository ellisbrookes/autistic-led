<div id="banner" class="bg-primary-500 text-white text-center py-4 px-6 md:px-0">
  <p>
    <% if @icon.present? %>
      <i class="fa-solid fa-<%= @icon %> mr-2"></i>
    <% end %>

    <%= @message %>

    <%= link_to @link_text, @link_path, class: "underline underline-offset-4 decoration-2 hover:text-white hover:underline-offset-6 transition-all duration-250 ease-in-out" %>
  </p>
</div>
