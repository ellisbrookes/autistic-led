<footer class="border-t border-slate-200 bg-white text-slate-800 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-200">

  <div class="mx-auto max-w-6xl px-4 py-12">

    <div class="grid grid-cols-1 gap-8 md:grid-cols-4">

      <!-- Company Info -->
      <div class="md:col-span-2">
        <div class="mb-4 flex items-center gap-4">
          <%= image_tag "nav-logo.png",
            alt: "Autistic Led Logo",
            class: "h-16 w-16 object-contain" %>

          <span class="text-3xl font-bold text-slate-900 dark:text-white">
            Autistic Led
          </span>
        </div>

        <p class="mb-4 max-w-md">
          The journey may vary but it is always Autistic Led.
        </p>

        <a href="https://www.facebook.com/AutisticLedSouthHolland"
           target="_blank"
           rel="noopener noreferrer"
           class="text-slate-500 transition-colors hover:text-slate-700 dark:text-slate-400 dark:hover:text-slate-200">
          <span class="sr-only">Facebook</span>

          <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24">
            <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
          </svg>
        </a>
      </div>

      <!-- Company Links -->
      <div>
        <h3 class="text-sm font-bold uppercase">Company</h3>

        <ul class="mt-4 space-y-3">
          <li><%= render Website::LinkComponent.new(text: "About", path: "#", variant: :small) %></li>
          <li><%= render Website::LinkComponent.new(text: "Blog", path: "#", variant: :small) %></li>
          <li><%= render Website::LinkComponent.new(text: "Contact", path: "#", variant: :small) %></li>
        </ul>
      </div>

    </div>

    <!-- Bottom section -->
    <div class="mt-10 flex flex-col items-center gap-3 text-center">

      <p class="text-sm">
        &copy; <%= Time.current.year %> Autistic Led. All rights reserved.
      </p>
      <p class="text-sm">
         Site Made by <%= link_to "Ellis Development", "https://ebrookes.dev", target: "_blank", rel: "noopener noreferrer", class: "underline" %>
      </p>

      <button type="button" class="mt-2 inline-flex items-center gap-2 rounded-md border border-slate-300 px-3 py-1.5 text-sm font-medium text-slate-700 transition-colors hover:bg-slate-100 dark:border-slate-600 dark:text-slate-100 dark:hover:bg-slate-700"
        data-action="click->theme#toggle"
        aria-label="Toggle theme">

        <svg class="block h-4 w-4 dark:hidden" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5">
          <circle cx="10" cy="10" r="3.25" />
          <path d="M10 1.5v1.75M10 16.75v1.75M3.75 10H2M18 10h-1.75M4.93 4.93l-1.24-1.24M16.31 16.31l-1.24-1.24M4.93 15.07l-1.24 1.24M16.31 3.69l-1.24 1.24" />
        </svg>

        <svg class="hidden h-4 w-4 dark:block" viewBox="0 0 20 20" fill="currentColor">
          <path d="M11.54 1.87a.75.75 0 0 0-1.16.8 7 7 0 0 1-8.01 9.92.75.75 0 0 0-.82 1.14A8.5 8.5 0 1 0 11.54 1.87Z"/>
        </svg>

        <span>Theme</span>
      </button>

    </div>

  </div>
</footer>