<footer class="flex flex-col items-center justify-center border-t border-slate-200 bg-slate-50 px-4 py-12 text-slate-800 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-200">
  <div class="grid grid-cols-1 gap-8 md:grid-cols-4">
    <!-- Company Info -->
    <div class="col-span-1 md:col-span-2">
      <div class="mb-4 flex items-center space-x-4">
        <div class="flex h-16 w-16 items-center justify-center">
          <%= image_tag "nav-logo.png", alt: "Autistic Led Logo", class: "h-16 w-16 object-contain" %>
        </div>

        <span class="text-3xl font-bold text-slate-900 dark:text-white">Autistic Led</span>
      </div>

      <p class="mb-4 max-w-md">
        The journey may vary but it is always Autistic Led.
      </p>

      <div class="flex space-x-4">
        <!-- Social Links -->
        <a href="https://www.facebook.com/AutisticLedSouthHolland" target="_blank" rel="noopener noreferrer" class="text-slate-500 transition-colors hover:text-slate-700 dark:text-slate-400 dark:hover:text-slate-200">
          <span class="sr-only">Facebook</span>
          <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24">
            <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
          </svg>
        </a>
      </div>
    </div>

    <!-- Company Links -->
    <div>
      <h3 class="text-sm font-bold uppercase">Company</h3>

      <ul class="mt-4 space-y-3">
        <li><%= render(Website::LinkComponent.new(text: "About", path: "#", variant: :small)) %></li>
        <li><%= render(Website::LinkComponent.new(text: "Blog", path: "#", variant: :small)) %></li>
        <li><%= render(Website::LinkComponent.new(text: "Contact", path: "#", variant: :small)) %></li>
      </ul>
    </div>
  </div>

  <!-- Bottom section -->
  <div class="flex w-full flex-col items-center justify-center gap-2 pt-4 text-center">
    <p>&copy; <%= Time.current.year %> Autistic Led. All rights reserved.</p>

    <div class="flex items-center gap-6">
      <%= render(Website::LinkComponent.new(text: "Privacy Policy", path: "#", variant: :small)) %>
      <%= render(Website::LinkComponent.new(text: "Terms of Service", path: "#", variant: :small)) %>
    </div>

    <button type="button" class="mt-1 inline-flex items-center gap-2 rounded-md border border-slate-300 px-3 py-1.5 text-sm font-medium text-slate-700 transition-colors hover:bg-slate-100 dark:border-slate-600 dark:text-slate-100 dark:hover:bg-slate-700" data-action="click->theme#toggle" aria-label="Toggle theme">
      <svg class="h-4 w-4 dark:hidden" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
        <path d="M10 1.75a.75.75 0 0 1 .75.75v1.5a.75.75 0 0 1-1.5 0V2.5a.75.75 0 0 1 .75-.75ZM10 15.75a.75.75 0 0 1 .75.75V18a.75.75 0 0 1-1.5 0v-1.5a.75.75 0 0 1 .75-.75ZM18.25 10a.75.75 0 0 1-.75.75H16a.75.75 0 0 1 0-1.5h1.5a.75.75 0 0 1 .75.75ZM4.75 10a.75.75 0 0 1-.75.75H2.5a.75.75 0 0 1 0-1.5H4a.75.75 0 0 1 .75.75ZM15.48 4.52a.75.75 0 0 1 1.06 0l1.06 1.06a.75.75 0 1 1-1.06 1.06l-1.06-1.06a.75.75 0 0 1 0-1.06ZM3.4 16.6a.75.75 0 0 1 1.06 0l1.06 1.06a.75.75 0 1 1-1.06 1.06L3.4 17.66a.75.75 0 0 1 0-1.06ZM16.54 15.48a.75.75 0 0 1 1.06 1.06l-1.06 1.06a.75.75 0 1 1-1.06-1.06l1.06-1.06ZM4.46 3.4a.75.75 0 0 1 1.06 1.06L4.46 5.52A.75.75 0 0 1 3.4 4.46L4.46 3.4ZM10 6a4 4 0 1 1 0 8 4 4 0 0 1 0-8Z" />
      </svg>
      <svg class="hidden h-4 w-4 dark:block" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
        <path d="M11.54 1.87a.75.75 0 0 0-1.16.8 7 7 0 0 1-8.01 9.92.75.75 0 0 0-.82 1.14A8.5 8.5 0 1 0 11.54 1.87Z" />
      </svg>
      <span>Theme</span>
    </button>
  </div>
</footer>
