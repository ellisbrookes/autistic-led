<nav class="border-b border-slate-200 bg-white/95 shadow-sm backdrop-blur dark:border-slate-700 dark:bg-slate-900/95" data-controller="mobile-menu">
  <div class="mx-auto max-w-7xl px-4">
    <div class="flex h-16 items-center justify-between">
      
      <!-- Logo -->
      <div class="flex items-center">
        <%= link_to root_path, class: "flex items-center space-x-3 sm:space-x-4" do %>
          <div class="flex h-10 w-10 sm:h-12 sm:w-12 items-center justify-center">
            <%= image_tag "nav-logo.png", alt: "Autistic Led Logo", class: "h-10 w-10 object-contain sm:h-12 sm:w-12" %>
          </div>
          <span class="text-lg font-bold text-slate-900 lg:text-xl dark:text-white">Autistic Led</span>
        <% end %>
      </div>

      <!-- Desktop Menu -->
      <div class="hidden lg:flex lg:items-center lg:space-x-3">
        <%= render(Website::NavLinkComponent.new(text: "Home", path: root_path)) %>
        <%= render(Website::NavLinkComponent.new(text: "Blog", path: blogs_path)) %>
        <% if helpers.authenticated? %>
          <%= render(Website::ButtonComponent.new(text: "Logout", path: logout_path, method: :delete, variant: :secondary, size: :sm)) %>
        <% else %>
          <%= render(Website::NavLinkComponent.new(text: "Login", path: login_path)) %>
        <% end %>
      </div>

      <!-- Mobile Hamburger -->
      <div class="flex items-center lg:hidden">
        <button type="button" class="rounded-md p-2 text-slate-700 hover:bg-slate-100 dark:text-slate-200 dark:hover:bg-slate-700" aria-label="Toggle navigation" aria-expanded="false" data-mobile-menu-target="button" data-action="click->mobile-menu#toggle">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>
      </div>

    </div>
  </div>

  <!-- Mobile Menu -->
  <div class="hidden border-t border-slate-200 bg-white px-4 py-4 dark:border-slate-700 dark:bg-slate-900" data-mobile-menu-target="menu">
    <div class="flex flex-col items-center space-y-4 text-base">
        <%= render(Website::NavLinkComponent.new(text: "Home", path: root_path)) %>
        <%= render(Website::NavLinkComponent.new(text: "Blog", path: blogs_path)) %>
        <% if helpers.authenticated? %>
          <%= render(Website::ButtonComponent.new(text: "Logout", path: logout_path, method: :delete, variant: :secondary, size: :sm)) %>
        <% else %>
          <%= render(Website::NavLinkComponent.new(text: "Login", path: login_path)) %>
        <% end %>
    </div>
  </div>
</nav>
