<% content_for :title, "Blogs" %>

<% if notice.present? %>
  <p
    id="notice"
    class="mb-5 inline-block rounded-md bg-primary-50 px-3 py-2 font-medium text-primary-700 dark:bg-primary-900/40 dark:text-primary-200"
  >
    <%= notice %>
  </p>
<% end %>

<%= render Website::SectionComponent.new do %>
  <div class="flex flex-col items-center gap-4">
    <h1 class="text-4xl font-bold tracking-tight">
      Blogs
    </h1>

    <% if authenticated? %>
      <%= render(Website::ButtonComponent.new(text: "New blog", path: new_blog_path, variant: :primary)) %>
    <% end %>
  </div>
<% end %>

<%= render Website::SectionComponent.new(variant: :fill) do %>
  <div
    id="blogs"
    class="grid grid-cols-1 gap-7 sm:grid-cols-2 lg:grid-cols-3"
  >
    <% if @blogs.any? %>
      <% @blogs.each do |blog| %>
        <% cover_image = blog.content&.embeds&.find { |attachment| attachment.blob.image? } %>

        <article class="group overflow-hidden rounded-2xl bg-primary-100 ring-1 ring-primary-200 shadow-[0_12px_35px_-18px_rgba(15,23,42,0.22)] transition-all duration-300 hover:-translate-y-1 hover:bg-primary-200 hover:ring-primary-300 hover:shadow-[0_24px_45px_-20px_rgba(15,23,42,0.3)] dark:bg-slate-800 dark:ring-slate-700 dark:hover:bg-slate-700 dark:hover:ring-slate-600">
          <%= link_to blog_path(blog), class: "block" do %>
            <% if cover_image.present? %>
              <%= image_tag cover_image,
                  alt: blog.title,
                  class: "h-48 w-full object-cover transition duration-300 group-hover:brightness-105" %>
            <% else %>
              <div class="h-48 w-full bg-gradient-to-br from-primary-100 via-primary-200 to-primary-300"></div>
            <% end %>

            <div class="p-5">
              <h2 class="text-xl font-semibold leading-tight text-slate-900 transition-colors duration-300 group-hover:text-primary-700 dark:text-slate-100 dark:group-hover:text-primary-300">
                <%= blog.title %>
              </h2>
            </div>
          <% end %>

          <% if authenticated? %>
            <div class="flex flex-wrap gap-2 px-5 pb-5">
              <%= render(Website::ButtonComponent.new(text: "Edit", path: edit_blog_path(blog), variant: :primary, size: :sm)) %>
              <%= render(Website::ButtonComponent.new(text: "Destroy", path: blog_path(blog), method: :delete, variant: :danger, size: :sm, form_class: "inline-flex", data: { turbo_confirm: "Are you sure?" })) %>
            </div>
          <% end %>
        </article>
      <% end %>
    <% else %>
      <p class="col-span-full my-10 text-center text-slate-600 dark:text-slate-300">
        No blogs found.
      </p>
    <% end %>
  </div>
<% end %>
