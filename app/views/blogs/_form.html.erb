<%= form_with(model: blog, class: "contents") do |form| %>
  <% if blog.errors.any? %>
    <div id="error_explanation" class="mt-3 rounded-md bg-red-50 px-3 py-2 font-medium text-red-600 dark:bg-red-900/30 dark:text-red-300">
      <h2><%= pluralize(blog.errors.count, "error") %> prohibited this blog from being saved:</h2>

      <ul class="list-disc ml-6">
        <% blog.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="my-5">
    <%= form.label :title, class: "font-medium text-slate-800 dark:text-slate-200" %>
    <%= form.text_field :title, class: ["mt-2 block w-full rounded-md border bg-white px-3 py-2 text-slate-900 shadow-sm dark:bg-slate-800 dark:text-slate-100", { "border-slate-300 focus:border-primary-500 focus:outline-none": blog.errors[:title].none?, "border-red-400 focus:border-red-500 focus:outline-none": blog.errors[:title].any? }] %>
  </div>

  <div class="blog-editor-field my-5">
    <%= form.label :content, class: "font-medium text-slate-800 dark:text-slate-200" %>
    <%= form.rich_text_area :content, class: "mt-2 block w-full" %>
  </div>

  <div class="mt-6 flex">
    <%= render(Website::ButtonComponent.new(text: (blog.persisted? ? "Update blog" : "Create blog"), type: "submit", variant: :primary, extra_classes: "w-full sm:w-auto")) %>
  </div>
<% end %>
