<div id="<%= dom_id blog %>" class="my-5 w-full space-y-5 rounded-xl border border-slate-200 bg-white p-5 shadow-sm dark:border-slate-700 dark:bg-slate-800 sm:w-auto">
  <div>
    <strong class="mb-1 block font-medium text-slate-700 dark:text-slate-300">Title:</strong>
    <%= blog.title %>
  </div>
  <div>
    <strong class="mb-1 block font-medium text-slate-700 dark:text-slate-300">Content:</strong>
    <%= blog.content %>
  </div>
</div>
