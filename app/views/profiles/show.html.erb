<% content_for :title, "Profile" %>

<%= render Website::SectionComponent.new(variant: :fill) do %>
  <div class="mx-auto my-auto w-full max-w-4xl">
    <div class="mb-6">
      <h1 class="text-3xl font-bold text-slate-900 dark:text-white">Account settings</h1>
      <p class="mt-1 text-sm text-slate-600 dark:text-slate-300">Update how your profile appears and keep your login details current.</p>
    </div>

    <% if notice.present? %>
      <p data-controller="flash-dismiss" data-flash-dismiss-delay-value="2800" class="mb-5 rounded-md border border-emerald-200 bg-emerald-50 px-3 py-2 font-medium text-emerald-700 transition-opacity duration-700 dark:border-emerald-700/50 dark:bg-emerald-900/30 dark:text-emerald-300"><%= notice %></p>
    <% end %>

    <% if alert.present? %>
      <p class="mb-5 rounded-md bg-red-50 px-3 py-2 font-medium text-red-700 dark:bg-red-900/30 dark:text-red-300"><%= alert %></p>
    <% end %>

    <% if @user.errors.any? %>
      <div class="mb-5 rounded-md border border-red-200 bg-red-50 px-3 py-2 text-sm text-red-700 dark:border-red-700/60 dark:bg-red-900/30 dark:text-red-300">
        <p class="font-semibold"><%= pluralize(@user.errors.count, "error") %> prevented saving:</p>
        <ul class="mt-2 list-inside list-disc space-y-1">
          <% @user.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="grid gap-6 lg:grid-cols-[0.9fr_1.1fr]">
      <div class="overflow-hidden rounded-2xl border border-slate-200 dark:border-slate-700">
        <div class="space-y-5 p-6">
          <h2 class="text-lg font-semibold text-slate-900 dark:text-white">Profile summary</h2>

          <div>
            <p class="text-xs font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-400">Display name</p>
            <p class="mt-1 text-lg font-semibold text-slate-900 dark:text-white"><%= @user.display_name %></p>
          </div>

          <div>
            <p class="text-xs font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-400">Email address</p>
            <p class="mt-1 text-base font-medium text-slate-900 dark:text-white"><%= @user.email_address %></p>
          </div>

          <div>
            <p class="text-xs font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-400">Role</p>
            <p class="mt-1 text-base font-medium text-slate-900 dark:text-white"><%= @user.role.humanize %></p>
          </div>

          <div>
            <p class="text-xs font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-400">Member since</p>
            <p class="mt-1 text-base font-medium text-slate-900 dark:text-white"><%= @user.created_at.strftime("%d %b %Y") %></p>
          </div>
        </div>
      </div>

      <div class="overflow-hidden rounded-2xl border border-slate-200 dark:border-slate-700">
        <div class="border-b border-slate-200 px-6 py-4 dark:border-slate-700">
          <h2 class="text-lg font-semibold text-slate-900 dark:text-white">Edit account</h2>
          <p class="mt-1 text-sm text-slate-600 dark:text-slate-300">Leave password fields empty if you do not want to change it.</p>
        </div>

        <%= form_with model: @user, url: profile_path, method: :patch, local: true, class: "space-y-6 p-6" do |form| %>
          <div>
            <%= form.label :name, "Display name", class: "font-medium text-slate-800 dark:text-slate-200" %>
            <%= form.text_field :name, required: true, class: "mt-2 block w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-slate-900 shadow-sm focus:border-primary-500 focus:outline-none dark:border-slate-600 dark:bg-slate-800 dark:text-slate-100" %>
          </div>

          <div>
            <%= form.label :email_address, "Email", class: "font-medium text-slate-800 dark:text-slate-200" %>
            <%= form.email_field :email_address, required: true, class: "mt-2 block w-full rounded-md border border-slate-300 bg-white px-3 py-2 text-slate-900 shadow-sm focus:border-primary-500 focus:outline-none dark:border-slate-600 dark:bg-slate-800 dark:text-slate-100" %>
          </div>

          <div class="space-y-2">
            <%= label_tag :user_current_password, "Current password (required to change email or password)", class: "font-medium text-slate-800 dark:text-slate-200" %>
            <div class="relative" data-controller="password-visibility">
              <%= password_field_tag "user[current_password]", nil, autocomplete: "current-password", data: { password_visibility_target: "input" }, class: "block w-full rounded-md border border-slate-300 bg-white px-3 py-2 pr-11 text-slate-900 shadow-sm focus:border-primary-500 focus:outline-none dark:border-slate-600 dark:bg-slate-800 dark:text-slate-100" %>
              <button type="button" class="absolute inset-y-0 right-0 inline-flex items-center px-3 text-slate-500 hover:text-slate-700 dark:text-slate-400 dark:hover:text-slate-200" data-action="password-visibility#toggle" aria-label="Show or hide current password">
                <svg data-password-visibility-target="showIcon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" class="h-5 w-5" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M2.25 12s3.75-6.75 9.75-6.75S21.75 12 21.75 12 18 18.75 12 18.75 2.25 12 2.25 12z" />
                  <circle cx="12" cy="12" r="3" stroke-width="1.8" />
                </svg>
                <svg data-password-visibility-target="hideIcon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" class="hidden h-5 w-5" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M3 3l18 18M10.58 10.58A3 3 0 0012 15a3 3 0 002.42-4.42M9.88 5.09A9.77 9.77 0 0112 4.88c6 0 9.75 7.12 9.75 7.12a16.75 16.75 0 01-4.64 5.58M6.56 6.56A16.97 16.97 0 002.25 12s3.75 6.75 9.75 6.75a9.8 9.8 0 003.12-.5" />
                </svg>
              </button>
            </div>
          </div>

          <p class="text-sm font-semibold text-slate-800 dark:text-slate-200">Change password</p>

            <div class="grid gap-4 sm:grid-cols-2">
              <div>
                <%= form.label :password, "New password", class: "font-medium text-slate-800 dark:text-slate-200" %>
                <div class="relative mt-2" data-controller="password-visibility">
                  <%= form.password_field :password, minlength: 8, autocomplete: "new-password", data: { password_visibility_target: "input" }, class: "block w-full rounded-md border border-slate-300 bg-white px-3 py-2 pr-11 text-slate-900 shadow-sm focus:border-primary-500 focus:outline-none dark:border-slate-600 dark:bg-slate-800 dark:text-slate-100" %>
                  <button type="button" class="absolute inset-y-0 right-0 inline-flex items-center px-3 text-slate-500 hover:text-slate-700 dark:text-slate-400 dark:hover:text-slate-200" data-action="password-visibility#toggle" aria-label="Show or hide new password">
                    <svg data-password-visibility-target="showIcon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" class="h-5 w-5" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M2.25 12s3.75-6.75 9.75-6.75S21.75 12 21.75 12 18 18.75 12 18.75 2.25 12 2.25 12z" />
                      <circle cx="12" cy="12" r="3" stroke-width="1.8" />
                    </svg>
                    <svg data-password-visibility-target="hideIcon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" class="hidden h-5 w-5" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M3 3l18 18M10.58 10.58A3 3 0 0012 15a3 3 0 002.42-4.42M9.88 5.09A9.77 9.77 0 0112 4.88c6 0 9.75 7.12 9.75 7.12a16.75 16.75 0 01-4.64 5.58M6.56 6.56A16.97 16.97 0 002.25 12s3.75 6.75 9.75 6.75a9.8 9.8 0 003.12-.5" />
                    </svg>
                  </button>
                </div>
              </div>

              <div>
                <%= form.label :password_confirmation, "Confirm password", class: "font-medium text-slate-800 dark:text-slate-200" %>
                <div class="relative mt-2" data-controller="password-visibility">
                  <%= form.password_field :password_confirmation, minlength: 8, autocomplete: "new-password", data: { password_visibility_target: "input" }, class: "block w-full rounded-md border border-slate-300 bg-white px-3 py-2 pr-11 text-slate-900 shadow-sm focus:border-primary-500 focus:outline-none dark:border-slate-600 dark:bg-slate-800 dark:text-slate-100" %>
                  <button type="button" class="absolute inset-y-0 right-0 inline-flex items-center px-3 text-slate-500 hover:text-slate-700 dark:text-slate-400 dark:hover:text-slate-200" data-action="password-visibility#toggle" aria-label="Show or hide confirmation password">
                    <svg data-password-visibility-target="showIcon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" class="h-5 w-5" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M2.25 12s3.75-6.75 9.75-6.75S21.75 12 21.75 12 18 18.75 12 18.75 2.25 12 2.25 12z" />
                      <circle cx="12" cy="12" r="3" stroke-width="1.8" />
                    </svg>
                    <svg data-password-visibility-target="hideIcon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" class="hidden h-5 w-5" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M3 3l18 18M10.58 10.58A3 3 0 0012 15a3 3 0 002.42-4.42M9.88 5.09A9.77 9.77 0 0112 4.88c6 0 9.75 7.12 9.75 7.12a16.75 16.75 0 01-4.64 5.58M6.56 6.56A16.97 16.97 0 002.25 12s3.75 6.75 9.75 6.75a9.8 9.8 0 003.12-.5" />
                    </svg>
                  </button>
                </div>
              </div>
            </div>

          <%= render(Website::ButtonComponent.new(text: "Save changes", type: "submit", variant: :primary, size: :md)) %>
        <% end %>
      </div>
    </div>
  </div>
<% end %>
