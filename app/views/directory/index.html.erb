<% content_for :title, "Active Directory" %>

<section class="relative overflow-hidden px-4 py-8 sm:py-12">
  <% if notice.present? %>
    <p class="mx-auto mb-5 w-full max-w-7xl rounded-md bg-green-50 px-3 py-2 text-sm font-medium text-green-700 dark:bg-green-900/30 dark:text-green-200" id="notice"><%= notice %></p>
  <% end %>
  <% if alert.present? %>
    <p class="mx-auto mb-5 w-full max-w-7xl rounded-md bg-red-50 px-3 py-2 text-sm font-medium text-red-700 dark:bg-red-900/30 dark:text-red-200"><%= alert %></p>
  <% end %>

  <div class="relative mx-auto grid w-full max-w-7xl gap-6 lg:grid-cols-[18rem_1fr]">

    <aside class="sticky top-6 h-fit rounded-2xl border p-5 shadow-sm backdrop-blur">
      <header>
        <h1 class="text-xl font-bold tracking-tight text-slate-900 dark:text-slate-100">Local Directory</h1>

        <p class="mt-2 text-sm leading-6 text-slate-700 dark:text-slate-300">
          A Place To Share Your Skills, Talents And Insights. If you're autistic or otherwise neurodivergent in Lincolnshire,  we want you to platform what you've got to offer the world!  
        </p>
      </header>

      <section class="-mx-5 mt-5 border-y border-slate-200 bg-slate-50 px-5 py-4 dark:border-slate-700 dark:bg-slate-900/50">
        <h2 class="text-xs font-semibold uppercase tracking-[0.12em] text-slate-700 dark:text-slate-200">Address radius</h2>

        <%= form_with url: directory_path, method: :get, local: true, class: "mt-3 space-y-3" do |form| %>
          <div>
            <%= form.label :category, "Category", class: "text-xs font-medium text-slate-700 dark:text-slate-300" %>
            <%= form.select :category, options_for_select([["All categories", ""]] + @category_options.map { |category| [category, category] }, @category_query), {}, class: "mt-1 block w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm shadow-sm focus:border-primary-500 focus:outline-none dark:border-slate-700 dark:bg-slate-800" %>
          </div>

          <div>
            <%= form.label :location, "Address or postcode", class: "text-xs font-medium text-slate-700 dark:text-slate-300" %>
            <%= form.text_field :location, value: @location_query, placeholder: "e.g. Lincoln", class: "mt-1 block w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm shadow-sm focus:border-primary-500 focus:outline-none dark:border-slate-700 dark:bg-slate-800" %>
          </div>

          <div>
            <%= form.label :radius, "Radius", class: "text-xs font-medium text-slate-700 dark:text-slate-300" %>
            <%= form.select :radius, options_for_select(@radius_options.map { |miles| ["#{miles} miles", miles] }, @radius_miles), {}, class: "mt-1 block w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm shadow-sm focus:border-primary-500 focus:outline-none dark:border-slate-700 dark:bg-slate-800" %>
          </div>

          <div class="flex gap-2">
            <%= form.submit "Apply", class: "inline-flex items-center rounded-md bg-slate-900 px-3 py-2 text-sm font-semibold text-white hover:bg-slate-800 dark:bg-slate-100 dark:text-slate-900 dark:hover:bg-white" %>
            <%= link_to "Clear", directory_path, class: "inline-flex items-center rounded-md border border-slate-300 px-3 py-2 text-sm font-semibold hover:bg-slate-100 dark:border-slate-700 dark:hover:bg-slate-800" %>
          </div>
        <% end %>
      </section>

      <nav class="mt-5">
        <h3 class="mb-2 text-xs font-semibold uppercase tracking-[0.12em] text-slate-600 dark:text-slate-300">Listings</h3>
        <ul class="space-y-2">
          <% @businesses.each do |business| %>
            <% next if business.name.to_s.strip.casecmp?("test") %>
            <li>
              <%= link_to directory_listing_path(business.id), class: "block rounded-lg border border-slate-200 px-3 py-2 text-sm font-medium text-slate-700 transition duration-200 hover:bg-slate-100 hover:text-slate-900 hover:shadow-sm dark:border-slate-700 dark:text-slate-200 dark:hover:bg-slate-800" do %>
                <%= business.name %>
              <% end %>
            </li>
          <% end %>

        </ul>
      </nav>
    </aside>

    <section class="space-y-5">
      <article
        id="join-directory"
        class="rounded-2xl border p-6 shadow-sm transition duration-200 hover:-translate-y-0.5 hover:shadow-md"
      >
        <header class="flex flex-wrap items-center gap-2">
          <h2 class="text-2xl font-semibold tracking-tight">
            Join Our Directory
          </h2>

          <span class="rounded-full bg-slate-200 px-3 py-1 text-xs font-semibold uppercase tracking-wide dark:bg-slate-700">
            Community
          </span>
        </header>

        <p class="mt-3 text-sm leading-6 text-slate-700 dark:text-slate-300">
          Want to feature your skills, talents or insights in our directory? Whether you're an autistic individual or a neurodivergent business in Lincolnshire, we invite you to share what you have to offer. Join our directory and connect with others in the community!
        </p>

        <div class="mt-4">
          <%= render(Website::ButtonComponent.new(text: "Post your listing", path: new_directory_listing_path, variant: :primary)) %>
        </div>
      </article>

      <% if @businesses.empty? %>
        <article class="rounded-2xl border p-6 shadow-sm">
          <p class="text-sm text-slate-600 dark:text-slate-300">
            <%= (@location_query.present? || @category_query.present?) ? "No listings match your filters yet." : "No listings yet. Be the first to post." %>
          </p>
        </article>
      <% end %>

      <% @businesses.each do |business| %>
        <article
          id="listing-<%= business.id %>"
          class="relative rounded-2xl border p-6 shadow-sm transition duration-200 hover:-translate-y-0.5 hover:shadow-md"
        >
          <%= link_to "", directory_listing_path(business.id), class: "absolute inset-0 z-10 rounded-2xl focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary-500 focus-visible:ring-offset-2", aria: { label: "View #{business.name}" } %>
          <% if business.cover_image.present? %>
            <div class="mb-4 overflow-hidden rounded-xl border border-slate-200 dark:border-slate-700">
              <%= image_tag business.cover_image, class: "h-52 w-full object-cover", alt: business.name %>
            </div>
          <% end %>

          <header class="flex flex-wrap items-center gap-2">
            <h2 class="text-xl font-semibold tracking-tight"><%= business.name %></h2>
            <% unless business.approved %>
              <span class="rounded-full bg-amber-100 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-amber-900">
                Pending approval
              </span>
            <% end %>
          </header>

          <p class="mt-2 text-sm text-slate-700 dark:text-slate-300">
            <span class="font-semibold">Address:</span>
            <%= business.location %>
          </p>

          <% if business.supports.present? %>
            <div class="mt-4">
              <h3 class="text-xs font-semibold uppercase tracking-[0.12em] text-slate-600 dark:text-slate-300">
                What we offer
              </h3>

              <ul class="mt-2 flex flex-wrap gap-2">
                <% business.supports.each do |support| %>
                  <li class="rounded-full bg-emerald-50 px-3 py-1 text-xs font-medium text-emerald-800">
                    <%= support %>
                  </li>
                <% end %>
              </ul>
            </div>
          <% end %>

          <% if business.notes.present? %>
            <p class="mt-4 text-sm leading-6 text-slate-700 dark:text-slate-300"><%= business.notes %></p>
          <% end %>

          <% if business.website_url.present? || business.contact_email.present? || business.location.present? %>
            <div class="relative z-20 mt-4 flex flex-wrap gap-3 text-sm">
              <% if business.website_url.present? %>
                <%= link_to "Website", business.website_url, class: "rounded-md border border-slate-300 px-3 py-1.5 font-medium hover:bg-slate-100 dark:border-slate-700 dark:hover:bg-slate-800" %>
              <% end %>
              <% if business.contact_email.present? %>
                <%= link_to "Email", "mailto:#{business.contact_email}", class: "rounded-md border border-slate-300 px-3 py-1.5 font-medium hover:bg-slate-100 dark:border-slate-700 dark:hover:bg-slate-800" %>
              <% end %>
              <% if business.location.present? %>
                <%= link_to "Map", "https://www.google.com/maps/search/?api=1&query=#{ERB::Util.url_encode(business.location.to_s)}", class: "rounded-md border border-slate-300 px-3 py-1.5 font-medium hover:bg-slate-100 dark:border-slate-700 dark:hover:bg-slate-800", target: "_blank", rel: "noopener noreferrer" %>
              <% end %>
            </div>
          <% end %>

          <% if admin? && business.id.present? %>
            <div class="relative z-20 mt-4 flex flex-wrap gap-2">
              <% if business.editable %>
                <%= render(Website::ButtonComponent.new(text: "Edit listing", path: edit_directory_listing_path(business.id), variant: :outline, size: :sm)) %>
              <% end %>
              <% unless business.approved %>
                <%= render(Website::ButtonComponent.new(text: "Approve listing", path: approve_directory_listing_path(business.id), method: :patch, variant: :secondary, size: :sm)) %>
              <% end %>
              <%= render(Website::ButtonComponent.new(text: "Remove listing", path: destroy_directory_listing_path(business.id), method: :delete, variant: :danger, size: :sm)) %>
            </div>
          <% end %>

          <% if !admin? && business.editable %>
            <div class="relative z-20 mt-4">
              <%= render(Website::ButtonComponent.new(text: "Edit listing", path: edit_directory_listing_path(business.id), variant: :outline, size: :sm)) %>
            </div>
          <% end %>
        </article>
      <% end %>

    </section>

  </div>
</section>
