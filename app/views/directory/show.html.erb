<% content_for :title, "Directory - #{@directory_listing.name}" %>

<%= render Website::SectionComponent.new do %>
  <div class="mx-auto w-full max-w-6xl">

    <% if notice.present? %>
      <p class="mb-5 inline-block rounded-md bg-green-50 px-3 py-2 font-medium text-green-700 dark:bg-green-900/30 dark:text-green-200">
        <%= notice %>
      </p>
    <% end %>

    <% if alert.present? %>
      <p class="mb-5 inline-block rounded-md bg-red-50 px-3 py-2 font-medium text-red-700 dark:bg-red-900/30 dark:text-red-200">
        <%= alert %>
      </p>
    <% end %>

    <div class="mb-6">
      <%= link_to directory_listings_path,
        class: "inline-flex items-center gap-2 text-sm font-medium text-slate-700 hover:text-slate-900 dark:text-slate-300 dark:hover:text-slate-100" do %>
        <span aria-hidden="true">&larr;</span>
        <span>Back</span>
      <% end %>
    </div>

    <section class="mt-4 overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm dark:border-slate-700 dark:bg-slate-900">

      <header class="border-b border-slate-200 px-5 py-6 sm:px-8 dark:border-slate-700">
        <div class="flex flex-wrap items-start justify-between gap-4">
          <div>
            <% listing_type = @directory_listing.listing_type.presence %>
            <% if listing_type && listing_type != @directory_listing.name %>
              <span class="rounded-full bg-slate-900 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-white dark:bg-slate-100 dark:text-slate-900">
                <%= listing_type %>
              </span>
            <% end %>

            <h1 class="mt-4 text-3xl font-bold tracking-tight text-slate-900 dark:text-slate-100 sm:text-4xl">
              <%= @directory_listing.name %>
            </h1>
          </div>

          <% website = safe_http_url(@directory_listing.website_url) %>
          <% button_classes = "rounded-md border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-800 hover:bg-slate-100 dark:border-slate-700 dark:bg-slate-800 dark:text-slate-100 dark:hover:bg-slate-700" %>

          <div class="flex flex-wrap gap-2">
            <%= link_to "Visit website", website, class: button_classes, rel: "noopener noreferrer", target: "_blank" if website.present? %>
            <%= link_to "Email", "mailto:#{@directory_listing.contact_email}", class: button_classes if @directory_listing.contact_email.present? %>
            <% if @directory_listing.location.present? %>
              <% map_url = "https://www.google.com/maps/search/?api=1&query=#{ERB::Util.url_encode(@directory_listing.location)}" %>
              <%= link_to "View map", map_url, class: button_classes, target: "_blank", rel: "noopener noreferrer" %>
            <% end %>
          </div>
        </div>
      </header>

      <div class="grid gap-4 p-4 sm:p-6 lg:grid-cols-[1.45fr_0.85fr]">

        <div class="space-y-5">

          <% if @directory_listing.cover_image.attached? %>
            <div class="overflow-hidden rounded-2xl border border-slate-200 dark:border-slate-700">
              <%= image_tag @directory_listing.cover_image,
                class: "h-64 w-full object-cover",
                alt: @directory_listing.name %>
            </div>
          <% end %>

          <% if @directory_listing.images.attached? %>
            <section class="rounded-2xl border border-slate-200 p-4 dark:border-slate-700">
              <h2 class="text-sm font-semibold uppercase tracking-wide text-slate-700 dark:text-slate-200">
                Images
              </h2>

              <div class="mt-2 grid gap-3 sm:grid-cols-2">
                <% @directory_listing.images.each do |image| %>
                  <%= image_tag image,
                    class: "h-48 w-full rounded-xl object-cover",
                    alt: @directory_listing.name %>
                <% end %>
              </div>
            </section>
          <% end %>

          <% if @directory_listing.description.present? %>
            <section class="rounded-2xl border border-slate-200 p-4 dark:border-slate-700">
              <div class="space-y-2">
                <h2 class="text-sm font-semibold uppercase tracking-wide text-slate-700 dark:text-slate-200">
                  About
                </h2>
                <p class="whitespace-pre-line text-sm leading-6 text-slate-700 dark:text-slate-200">
                  <%= @directory_listing.description %>
                </p>
              </div>
            </section>
          <% end %>

          <% if @directory_listing.location.present? %>
            <% map_embed = "https://www.google.com/maps?q=#{ERB::Util.url_encode(@directory_listing.location)}&output=embed" %>

            <section class="rounded-2xl border border-slate-200 p-4 dark:border-slate-700">
              <h2 class="text-sm font-semibold uppercase tracking-wide text-slate-700 dark:text-slate-200 mb-2">
                Location
              </h2>
              <p class="text-sm text-slate-700 dark:text-slate-300"><%= @directory_listing.location %></p>
              <div class="mt-3 overflow-hidden rounded-xl border border-slate-200 dark:border-slate-700">
                <iframe
                  title="Map for <%= @directory_listing.name %>"
                  src="<%= map_embed %>"
                  class="h-72 w-full"
                  loading="lazy"
                  referrerpolicy="no-referrer-when-downgrade">
                </iframe>
              </div>
            </section>
          <% end %>

          <% if @directory_listing.support_tags.present? %>
            <section class="rounded-2xl border border-slate-200 p-4 dark:border-slate-700">
              <h2 class="text-sm font-semibold uppercase tracking-wide text-slate-700 dark:text-slate-200 mb-2">
                What we offer
              </h2>
              <ul class="grid gap-2 sm:grid-cols-2">
                <% @directory_listing.support_tags.each do |support| %>
                  <li class="rounded-lg border border-emerald-200 bg-emerald-50 px-3 py-2 text-sm font-medium text-emerald-900 dark:border-emerald-800 dark:bg-emerald-900/20 dark:text-emerald-100">
                    <%= support %>
                  </li>
                <% end %>
              </ul>
            </section>
          <% end %>

        </div>

        <aside class="space-y-4">

          <section class="rounded-2xl border border-slate-200 bg-slate-50 p-4 dark:border-slate-700 dark:bg-slate-900/60">
            <div class="space-y-2">
              <h2 class="text-sm font-semibold uppercase tracking-wide text-slate-700 dark:text-slate-200">
                Business details
              </h2>

              <dl class="space-y-3 text-sm">
              <div class="flex justify-between border-b border-slate-200 pb-2 dark:border-slate-700">
                <dt class="text-slate-600 dark:text-slate-300">Listed</dt>
                <dd class="font-semibold text-slate-900 dark:text-slate-100">
                  <%= @directory_listing.created_at.to_date.to_fs(:short) %>
                </dd>
              </div>

              <div class="flex justify-between">
                <dt class="text-slate-600 dark:text-slate-300">Updated</dt>
                <dd class="font-semibold text-slate-900 dark:text-slate-100">
                  <%= @directory_listing.updated_at.to_date.to_fs(:short) %>
                </dd>
              </div>
            </dl>
          </section>

          <% can_manage = admin? || @directory_listing.user_id == current_user&.id %>

          <% if can_manage %>
            <section class="rounded-2xl border border-slate-200 bg-slate-50 p-4 dark:border-slate-700 dark:bg-slate-900/60">
              <div class="space-y-2">
                <h2 class="text-sm font-semibold uppercase tracking-wide text-slate-700 dark:text-slate-200">
                  Manage listing
                </h2>

              <div class="mt-2 flex flex-wrap gap-1.5">

                <%= render Website::ButtonComponent.new(
                  text: "Edit listing",
                  path: edit_directory_listing_path(@directory_listing),
                  variant: :outline,
                  size: :sm
                ) %>

                <% if admin? && !@directory_listing.approved? %>
                  <%= render Website::ButtonComponent.new(
                    text: "Approve listing",
                    path: approve_directory_listing_path(@directory_listing),
                    method: :patch,
                    variant: :secondary,
                    size: :sm
                  ) %>
                <% end %>

                <% if admin? %>
                  <%= render Website::ButtonComponent.new(
                    text: "Remove listing",
                    path: directory_listing_path(@directory_listing),
                    method: :delete,
                    variant: :danger,
                    size: :sm,
                    data: { turbo_confirm: "Remove this listing?" }
                  ) %>
                <% end %>

              </div>
            </section>
          <% end %>

        </aside>

      </div>
    </section>
  </div>
<% end %>
