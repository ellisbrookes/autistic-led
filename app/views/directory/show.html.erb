<% content_for :title, "Directory - #{@directory_listing.name}" %>

<%= render Website::SectionComponent.new do %>
  <div class="mx-auto w-full max-w-6xl">
    <% if notice.present? %>
      <p class="mb-5 inline-block rounded-md bg-green-50 px-3 py-2 font-medium text-green-700 dark:bg-green-900/30 dark:text-green-200" id="notice"><%= notice %></p>
    <% end %>
    <% if alert.present? %>
      <p class="mb-5 inline-block rounded-md bg-red-50 px-3 py-2 font-medium text-red-700 dark:bg-red-900/30 dark:text-red-200"><%= alert %></p>
    <% end %>

    <%= link_to directory_path, class: "inline-flex items-center gap-2 text-sm font-medium text-slate-700 hover:text-slate-900 dark:text-slate-300 dark:hover:text-slate-100" do %>
      <span aria-hidden="true">&larr;</span>
      <span>Back to directory</span>
    <% end %>

    <section class="mt-4 overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm dark:border-slate-700 dark:bg-slate-900">
      <header class="border-b border-slate-200 bg-gradient-to-r from-amber-100 via-yellow-50 to-white px-5 py-6 dark:border-slate-700 dark:from-slate-800 dark:via-slate-900 dark:to-slate-900 sm:px-8">
        <div class="flex flex-wrap items-start justify-between gap-4">
          <div>
            <div class="flex flex-wrap items-center gap-2">
              <span class="rounded-full bg-slate-900 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-white dark:bg-slate-100 dark:text-slate-900"><%= @directory_listing.listing_type %></span>
            </div>
            <h1 class="mt-4 text-3xl font-bold tracking-tight text-slate-900 dark:text-slate-100 sm:text-4xl"><%= @directory_listing.name %></h1>
            <p class="mt-2 text-sm text-slate-700 dark:text-slate-300"><span class="font-semibold">Location:</span> <%= @directory_listing.location %></p>
          </div>

          <div class="flex flex-wrap gap-2">
            <% if @directory_listing.website_url.present? %>
              <%= link_to "Visit website", @directory_listing.website_url, class: "rounded-md border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-800 hover:bg-slate-100 dark:border-slate-700 dark:bg-slate-800 dark:text-slate-100 dark:hover:bg-slate-700" %>
            <% end %>
            <% if @directory_listing.contact_email.present? %>
              <%= link_to "Email", "mailto:#{@directory_listing.contact_email}", class: "rounded-md border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-800 hover:bg-slate-100 dark:border-slate-700 dark:bg-slate-800 dark:text-slate-100 dark:hover:bg-slate-700" %>
            <% end %>
          </div>
        </div>
      </header>

      <div class="grid gap-6 p-5 sm:p-8 lg:grid-cols-[1.45fr_0.85fr]">
        <div class="space-y-6">
          <% if @directory_listing.images.attached? %>
            <section class="rounded-2xl border border-slate-200 p-5 dark:border-slate-700">
              <h2 class="text-sm font-semibold uppercase tracking-wide text-slate-700 dark:text-slate-200">Images</h2>
              <div class="mt-3 grid gap-3 sm:grid-cols-2">
                <% @directory_listing.images.each do |image| %>
                  <%= image_tag image, class: "h-48 w-full rounded-xl object-cover", alt: @directory_listing.name %>
                <% end %>
              </div>
            </section>
          <% end %>

          <section class="rounded-2xl border border-slate-200 p-5 dark:border-slate-700">
            <h2 class="text-sm font-semibold uppercase tracking-wide text-slate-700 dark:text-slate-200">About</h2>
            <p class="mt-3 whitespace-pre-line text-sm leading-7 text-slate-700 dark:text-slate-200"><%= @directory_listing.description %></p>
          </section>

          <% if @directory_listing.support_tags.present? %>
            <section class="rounded-2xl border border-slate-200 p-5 dark:border-slate-700">
              <h2 class="text-sm font-semibold uppercase tracking-wide text-slate-700 dark:text-slate-200">What we offer</h2>
              <ul class="mt-3 grid gap-2 sm:grid-cols-2">
                <% @directory_listing.support_tags.each do |support| %>
                  <li class="rounded-lg border border-emerald-200 bg-emerald-50 px-3 py-2 text-sm font-medium text-emerald-900 dark:border-emerald-800 dark:bg-emerald-900/20 dark:text-emerald-100"><%= support %></li>
                <% end %>
              </ul>
            </section>
          <% end %>
        </div>

        <aside class="space-y-4">
          <section class="rounded-2xl border border-slate-200 bg-slate-50 p-5 dark:border-slate-700 dark:bg-slate-900/60">
            <h2 class="text-sm font-semibold uppercase tracking-wide text-slate-700 dark:text-slate-200">Business details</h2>
            <dl class="mt-4 space-y-3 text-sm">
              <div class="flex items-center justify-between gap-3 border-b border-slate-200 pb-2 dark:border-slate-700">
                <dt class="text-slate-600 dark:text-slate-300">Listed on</dt>
                <dd class="font-semibold text-slate-900 dark:text-slate-100"><%= @directory_listing.created_at.strftime("%d %b %Y") %></dd>
              </div>
              <div class="flex items-center justify-between gap-3">
                <dt class="text-slate-600 dark:text-slate-300">Updated</dt>
                <dd class="font-semibold text-slate-900 dark:text-slate-100"><%= @directory_listing.updated_at.strftime("%d %b %Y") %></dd>
              </div>
            </dl>
          </section>

          <% if admin? || @directory_listing.user_id == current_user&.id %>
            <section class="rounded-2xl border border-slate-200 bg-slate-50 p-5 dark:border-slate-700 dark:bg-slate-900/60">
              <h2 class="text-sm font-semibold uppercase tracking-wide text-slate-700 dark:text-slate-200">Manage listing</h2>
              <div class="mt-4 flex flex-wrap gap-2">
                <%= render(Website::ButtonComponent.new(text: "Edit listing", path: edit_directory_listing_path(@directory_listing), variant: :outline, size: :sm)) %>
                <% if admin? && !@directory_listing.approved? %>
                  <%= render(Website::ButtonComponent.new(text: "Approve listing", path: approve_directory_listing_path(@directory_listing), method: :patch, variant: :secondary, size: :sm)) %>
                <% end %>
                <% if admin? %>
                  <%= render(Website::ButtonComponent.new(text: "Remove listing", path: destroy_directory_listing_path(@directory_listing), method: :delete, variant: :danger, size: :sm, data: { turbo_confirm: "Remove this listing?" })) %>
                <% end %>
              </div>
            </section>
          <% end %>
        </aside>
      </div>
    </section>
  </div>
<% end %>
