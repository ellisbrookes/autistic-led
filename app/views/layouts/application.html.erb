<!DOCTYPE html>
<html data-controller="theme">
  <head>
    <title><%= content_for?(:title) ? "Autistic Led - #{content_for(:title)}" : "Autistic Led" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Autistic Led">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="shortcut icon" href="/favicon.ico">
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "actiontext", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="flex min-h-screen flex-col">

    <!-- Navigation-->
    <%= render Website::NavigationComponent.new %>

    <!-- Page content -->
    <main class="flex flex-1 flex-col">
      <%= yield %>
    </main>

    <!-- Footer -->
    <%= render Website::FooterComponent.new %>
  </body>
</html>
