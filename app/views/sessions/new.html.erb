<% content_for :title, "Login" %>

<%= render Website::SectionComponent.new() do %>
  <div class="mx-auto max-w-md w-full">
    <h1 class="font-bold text-4xl mb-6">Login</h1>

    <% if alert.present? %>
      <p class="py-2 px-3 bg-red-50 mb-5 text-red-600 font-medium rounded-md"><%= alert %></p>
    <% end %>

    <%= form_with url: session_path do |form| %>
      <div class="my-5">
        <%= form.label :email_address, "Email" %>
        <%= form.email_field :email_address, required: true, autofocus: true, class: "block shadow-sm rounded-md border border-gray-400 px-3 py-2 mt-2 w-full" %>
      </div>

      <div class="my-5">
        <%= form.label :password %>
        <%= form.password_field :password, required: true, class: "block shadow-sm rounded-md border border-gray-400 px-3 py-2 mt-2 w-full" %>
      </div>

      <%= form.submit "Log in", class: "w-full sm:w-auto rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 inline-block font-medium cursor-pointer" %>
    <% end %>
  </div>
<% end %>
